rules_version = '2';

// ============================================================================
// Kora — Firestore Security Rules
// Model: tiap user hanya boleh menulis datanya sendiri. Data kesehatan/GPS
// (workouts, nutrition, schedule, body_measurements) PRIVAT — tidak bisa
// dibaca user lain. Data sosial (profil, feed, follow) boleh dibaca publik
// oleh user yang sudah login, tapi penulisannya dibatasi ketat.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Field yang berubah pada sebuah update (set yang baru, tidak termasuk yang sama)
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ── /users/{uid} ─────────────────────────────────────────────────────────
    // Dokumen profil. Boleh DIBACA siapa saja yang login (untuk search,
    // public profile, ambil fcmToken untuk notifikasi). Hanya pemilik yang
    // boleh menulis profilnya sendiri.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(uid);

      // ── Data PRIVAT: hanya pemilik yang boleh baca & tulis ─────────────────
      match /workouts/{workoutId} {
        allow read, write: if isOwner(uid);

        match /photos/{photoId} {
          allow read, write: if isOwner(uid);
        }
      }

      match /nutrition/{dateId} {
        allow read, write: if isOwner(uid);
      }

      match /schedule_events/{eventId} {
        allow read, write: if isOwner(uid);
      }

      match /body_measurements/{measurementId} {
        allow read, write: if isOwner(uid);
      }

      // ── following: daftar orang yang DIIKUTI oleh {uid} ────────────────────
      // Hanya pemilik akun yang boleh menambah/menghapus following-nya.
      // Boleh dibaca user login (untuk hitung jumlah & susun feed).
      match /following/{followedId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(uid);
      }

      // ── followers: daftar PENGIKUT dari {uid} ──────────────────────────────
      // Saat A follow B, A menulis dokumen followers/{A} di akun B.
      // Jadi: si follower boleh menambah dirinya sendiri; pemilik akun
      // boleh menghapus follower (remove follower). Si follower juga boleh
      // menghapus dirinya (unfollow).
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isOwner(followerId);
        allow delete: if isOwner(followerId) || isOwner(uid);
      }

      // ── notifications: kotak notifikasi milik {uid} ────────────────────────
      // Hanya pemilik yang boleh MEMBACA notifikasinya.
      // User lain boleh MEMBUAT notifikasi (mis. saat like/follow/komentar),
      // tapi wajib menandai dirinya sebagai pengirim (relatedUid == auth.uid).
      // Update (tandai sudah dibaca) & hapus hanya oleh pemilik.
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow create: if isSignedIn()
                      && request.resource.data.relatedUid == request.auth.uid;
        allow update, delete: if isOwner(uid);
      }
    }

    // ── /feed_posts/{postId} ─────────────────────────────────────────────────
    // Feed sosial. Boleh dibaca semua user login. Membuat post hanya boleh
    // jika field uid == pembuat. Update dibatasi: pemilik boleh apa saja;
    // user lain HANYA boleh mengubah 'likedBy' dan 'commentsCount'
    // (untuk fitur like & komentar). Hapus hanya pemilik.
    match /feed_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(resource.data.uid);
      allow update: if isOwner(resource.data.uid)
                    || (isSignedIn()
                        && changedKeys().hasOnly(['likedBy', 'commentsCount']));

      // ── comments ───────────────────────────────────────────────────────────
      // Boleh dibaca semua user login. Komentar baru harus menandai
      // pembuatnya (uid == auth.uid). Hanya pembuat komentar yang boleh
      // mengubah/menghapus komentarnya.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isOwner(resource.data.uid);
      }
    }

    // ── Default: tolak semua yang tidak cocok aturan di atas ─────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
