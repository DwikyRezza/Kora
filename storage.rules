rules_version = '2';

// ============================================================================
// Kora — Firebase Storage Rules
// Catatan: aplikasi saat ini menyimpan foto sebagai base64 di Firestore
// (lihat StorageService), jadi Storage praktis belum dipakai. Rules ini
// bersifat aman secara default: tiap user hanya boleh mengakses foldernya
// sendiri di users/{uid}/..., dengan batas ukuran & tipe file. Selain itu
// ditolak.
// ============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isImageUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    // Folder pribadi per user
    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isImageUnder5MB();
    }

    // Default: tolak semua
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
